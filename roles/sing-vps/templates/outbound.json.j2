{
    "outbounds": [
        {
            "network": "tcp",
            "server": "{{ ansible_host }}",
            "server_port": 443,
            "tag": "jlbk-vless",
            "tls": {
              "enabled": true,
              "max_version": "1.3",
              "min_version": "1.2",
              "server_name": "{{ domain }}"
            },
            "type": "vless",
            "transport": {
              "early_data_header_name": "Sec-WebSocket-Protocol",
              "headers": {
                "Host": "{{ domain }}"
              },
              "max_early_data": 2048,
              "path": "/wsbackend",
              "type": "ws"
            },
            "uuid": "{{ uuid }}"
        }
    ]
}